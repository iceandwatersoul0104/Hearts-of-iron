    {
      "id": "cf_priest_entry",
      "locationTitle": "暗影森林 · 亡灵小径",
      "musicKey": "forest_mystic",
      "type": "narrative",
      "text": "这条小径两旁的树上挂着残破的布条和锈蚀的兵器——这是战场遗址。被杀死的士兵没有被安葬，黑暗魔力把它们的怨念变成了活动尸。\n\n骷髅从地下破土而出——空洞的眼眶中燃烧着暗绿色的鬼火。\n\n「亡者当安息。」你举起钉头锤——圣光在锤头上聚集。",
      "nextNodeId": "cf_priest_skeleton"
    },
    {
      "id": "cf_priest_skeleton",
      "locationTitle": "暗影森林 · 亡灵小径",
      "musicKey": "forest_battle",
      "type": "choice",
      "text": "四具骷髅举着锈剑向你走来——它们的步伐僵硬但不停歇。",
      "choices": [
        {
          "text": "【净化】以圣光之力赐予亡者安息",
          "isCombat": true,
          "combatThreshold": 40,
          "bonusClasses": ["priest"],
          "successNodeId": "cf_priest_skel_done",
