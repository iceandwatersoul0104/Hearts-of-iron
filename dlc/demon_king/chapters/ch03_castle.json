  "nodes": [
    {
      "id": "cc_chapter_start",
      "locationTitle": "魔王城 · 外围",
      "musicKey": "castle_theme",
      "type": "narrative",
      "text": "魔王城——\n\n它比你想象中更大。黑色的尖塔刺入血红色的天空，城墙是用不知道什么生物的骨头砌成的。空气中弥漫着硫磺和灰烬的味道。\n\n从启程之村走到这里，已经过了两个月。你打败了哥布林王，穿越了暗影森林，击杀了暗精灵领主。\n\n现在——你站在魔王军的大本营前。\n\n四大天王在城内守卫。打败他们——才能见到魔王。",
      "nextNodeId": "cc_exit",
      "classText": {
        "hero": "你的剑从未如此明亮——它在渴望斩除这世间最大的邪恶。",
        "warrior": "你握紧战斧。两个月的旅程——就是为了今天。没有什么能挡住你。",
        "archer": "你在城外的高地上观察着城堡的防御。城墙上有射击孔——但也有死角。",
        "mage": "魔王城的魔力波动让空气都在震颤。这里面的魔力源——是你这辈子感受过的最强的。",
        "priest": "整座城堡散发着令人窒息的邪气。圣光在你体内燃烧——它不允许你在此退缩。"
      }
    },
    {
      "id": "cc_exit",
      "locationTitle": "魔王城 · 外围",
      "musicKey": "castle_theme",
      "type": "choice",
      "text": "你检查着装备和状态。两个月的历练，你已今非昔比。\n\n魔王城的大门就在前方——",
      "choices": [
        { "text": "【前进】进军魔王城", "nextNodeId": "cc_hero_entry", "classRestricted": true, "allowedClasses": ["hero"], "grantedFlags": ["lvl_10", "hero_steel_sword", "armor_chain"] },
        { "text": "【前进】进军魔王城", "nextNodeId": "cc_warrior_entry", "classRestricted": true, "allowedClasses": ["warrior"], "grantedFlags": ["lvl_10", "war_battle_axe", "armor_chain"] },
        { "text": "【前进】进军魔王城", "nextNodeId": "cc_archer_entry", "classRestricted": true, "allowedClasses": ["archer"], "grantedFlags": ["lvl_10", "arc_long_bow", "armor_chain"] },
        { "text": "【前进】进军魔王城", "nextNodeId": "cc_mage_entry", "classRestricted": true, "allowedClasses": ["mage"], "grantedFlags": ["lvl_10", "mag_arcane_staff", "armor_chain"] },
        { "text": "【前进】进军魔王城", "nextNodeId": "cc_priest_entry", "classRestricted": true, "allowedClasses": ["priest"], "grantedFlags": ["lvl_10", "pri_blessed_mace", "armor_chain"] }
      ]
    },

    {
      "id": "cc_hero_entry",
      "locationTitle": "魔王城 · 城门",
      "musicKey": "castle_theme",
      "type": "narrative",
      "text": "你是勇者。你不绕路——你走正门。\n\n城门前的两个黑暗骑士注意到你，长枪平举，马铠在月光下反射出冷光。\n\n你拔出剑——剑光在黑暗中划出一条金色的线。",
      "nextNodeId": "cc_hero_gate"
    },
    {
      "id": "cc_hero_gate",
      "locationTitle": "魔王城 · 城门",
      "musicKey": "castle_theme",
      "type": "choice",
      "text": "「让开——或者死。」\n\n黑暗骑士没有回答。它们策马冲锋——",
      "choices": [
        {
          "text": "【圣剑斩】以勇者之力正面迎击",
          "isCombat": true, "combatThreshold": 50,
          "bonusClasses": ["hero"],
          "successNodeId": "cc_hero_gate_done", "failureNodeId": "cc_hero_gate_hurt",
          "failHpDelta": -25, "failMoraleDelta": -15,
          "grantedFlags": ["lvl_11"]
        }
      ]
    },
    {
      "id": "cc_hero_gate_done",
      "locationTitle": "魔王城 · 城门",
      "musicKey": "castle_theme",
      "type": "narrative",
      "text": "剑光划过——两个黑暗骑士连人带马裂成两半。\n\n你甩掉剑上的黑血。正门已通——但城里还有更强大的敌人在等。\n\n勇者从不绕路。",
      "nextNodeId": "cc_gate_converge",
      "hpDelta": 0, "moraleDelta": 15
    },
    {
      "id": "cc_hero_gate_hurt",
      "locationTitle": "魔王城 · 城门",
      "musicKey": "castle_theme",
      "type": "narrative",
      "text": "黑暗骑士的长枪擦过了你的肩膀——但你还是把它们两个都斩了。\n\n伤口火辣辣的，但不深。你继续前进——正门已破。",
      "nextNodeId": "cc_gate_converge",
      "hpDelta": 0, "moraleDelta": 5
    },

    {
      "id": "cc_warrior_entry",
      "locationTitle": "魔王城 · 外墙",
      "musicKey": "castle_theme",
      "type": "narrative",
      "text": "正门太慢了。你看中了城墙上的一处薄弱点——一次精准的冲锋就能撞开。\n\n你举起战斧，后退几步——然后像一头蛮牛一样冲了过去。",
      "nextNodeId": "cc_warrior_wall"
    },
    {
      "id": "cc_warrior_wall",
      "locationTitle": "魔王城 · 外墙",
      "musicKey": "castle_theme",
      "type": "choice",
      "text": "城墙上的黑暗守卫发现你了——弓箭和魔法弹幕倾泻而下。但你不在乎——你只在乎眼前的墙。",
      "choices": [
        {
          "text": "【破墙】用斧头砸穿城墙",
          "isCombat": true, "combatThreshold": 50,
          "bonusClasses": ["warrior"],
          "successNodeId": "cc_warrior_wall_done", "failureNodeId": "cc_warrior_wall_hurt",
          "failHpDelta": -25, "failMoraleDelta": -15,
          "grantedFlags": ["lvl_11"]
        }
      ]
    },
    {
      "id": "cc_warrior_wall_done",
      "locationTitle": "魔王城 · 外墙",
      "musicKey": "castle_theme",
      "type": "narrative",
      "text": "墙壁在斧头下崩塌——你从瓦砾中冲进了城内。守军目瞪口呆地看着你——这哪是人啊，简直就是一台攻城锤。\n\n你拍了拍身上的灰：「战士就要走战士的路。」",
      "nextNodeId": "cc_gate_converge",
      "hpDelta": 0, "moraleDelta": 15
    },
    {
      "id": "cc_warrior_wall_hurt",
      "locationTitle": "魔王城 · 外墙",
      "musicKey": "castle_theme",
      "type": "narrative",
      "text": "你撞开了墙——但是也挨了好几箭。箭头卡在护甲上，不深——但疼。\n\n你拔掉箭杆，不管它了。城内——战斗等着你。",
      "nextNodeId": "cc_gate_converge",
      "hpDelta": 0, "moraleDelta": 5
    },

    {
      "id": "cc_archer_entry",
      "locationTitle": "魔王城 · 城墙上",
      "musicKey": "castle_theme",
      "type": "narrative",
      "text": "正门？太显眼了。你找到了城墙上的一个暗哨入口——狭窄、隐蔽，守军只有两个。\n\n你的弓在黑暗中优势尽显——先发制人。",
      "nextNodeId": "cc_archer_stealth"
    },
    {
      "id": "cc_archer_stealth",
      "locationTitle": "魔王城 · 城墙上",
      "musicKey": "castle_theme",
      "type": "choice",
      "text": "两个守卫背对着你。风从东边吹来——箭矢的轨迹不会偏。\n\n你搭箭——瞄准——",
      "choices": [
        {
          "text": "【暗杀】一箭双杀——快速解决",
          "isCombat": true, "combatThreshold": 50,
          "bonusClasses": ["archer"],
          "successNodeId": "cc_archer_done", "failureNodeId": "cc_archer_hurt",
          "failHpDelta": -25, "failMoraleDelta": -15,
          "grantedFlags": ["lvl_11"]
        }
      ]
    },
    {
      "id": "cc_archer_done",
      "locationTitle": "魔王城 · 城墙上",
      "musicKey": "castle_theme",
      "type": "narrative",
      "text": "两支箭——两个守卫无声地倒下。没人看到你。\n\n你从暗处潜入城内——猎人最擅长的就是不被猎物发现。",
      "nextNodeId": "cc_gate_converge",
      "hpDelta": 0, "moraleDelta": 15
    },
    {
      "id": "cc_archer_hurt",
      "locationTitle": "魔王城 · 城墙上",
      "musicKey": "castle_theme",
      "type": "narrative",
      "text": "第一箭命中——但第二箭擦过了守卫的盔甲。它发出了警报才被你射死。\n\n更多守卫正在赶来——你快速潜入城中。不完美，但进来了。",
      "nextNodeId": "cc_gate_converge",
      "hpDelta": 0, "moraleDelta": 0
    },

    {
      "id": "cc_mage_entry",
      "locationTitle": "魔王城 · 魔法结界前",
      "musicKey": "castle_theme",
      "type": "narrative",
      "text": "魔王城的城墙被一层魔法结界保护着。普通士兵根本无法靠近——但你不是普通士兵。\n\n你感受到了结界中的裂缝——黑暗魔力虽然强大，但不稳定。只需要在正确的点上释放一道精准的法术——",
      "nextNodeId": "cc_mage_barrier"
    },
    {
      "id": "cc_mage_barrier",
      "locationTitle": "魔王城 · 魔法结界前",
      "musicKey": "castle_theme",
      "type": "choice",
      "text": "结界察觉到了你的魔力——法术反噬的冲击波袭来。但你准备好了。",
      "choices": [
        {
          "text": "【破界】以奥术之力撕裂结界",
          "isCombat": true, "combatThreshold": 50,
          "bonusClasses": ["mage"],
          "successNodeId": "cc_mage_done", "failureNodeId": "cc_mage_hurt",
          "failHpDelta": -25, "failMoraleDelta": -15,
          "grantedFlags": ["lvl_11"]
        }
      ]
    },
    {
      "id": "cc_mage_done",
      "locationTitle": "魔王城 · 魔法结界前",
      "musicKey": "castle_theme",
      "type": "narrative",
      "text": "结界在你的法术下像玻璃一样碎裂。黑暗魔力反噬了施法者——不知道那个倒霉的法师在城里哪个角落吐血。\n\n你优雅地穿过结界碎片——大摇大摆地走进了魔王城。",
      "nextNodeId": "cc_gate_converge",
      "hpDelta": 0, "moraleDelta": 15
    },
    {
      "id": "cc_mage_hurt",
      "locationTitle": "魔王城 · 魔法结界前",
      "musicKey": "castle_theme",
      "type": "narrative",
      "text": "结界反噬比你预想的更强——你被冲击波震退，内脏翻涌。但结界确实破了。\n\n你擦掉嘴角的血——这点代价，值得。",
      "nextNodeId": "cc_gate_converge",
      "hpDelta": 0, "moraleDelta": 5
    },

    {
      "id": "cc_priest_entry",
      "locationTitle": "魔王城 · 地下暗道",
      "musicKey": "castle_theme",
      "type": "narrative",
      "text": "圣光指引着你——不是走向正门，而是走向一处隐蔽的暗道。这是很久以前被关押在魔王城里的圣职者挖的逃生通道。\n\n暗道尽头是城堡的地下圣堂——曾经是圣光的领地，现在被黑暗玷污了。\n\n你需要净化它——然后通过圣堂进入城堡。",
      "nextNodeId": "cc_priest_chapel"
    },
    {
      "id": "cc_priest_chapel",
      "locationTitle": "魔王城 · 地下圣堂",
      "musicKey": "castle_theme",
      "type": "choice",
      "text": "圣坛已经被黑暗腐蚀——邪物在上面筑巢。一只暗影恶魔盘踞在上方，它的眼睛像两团黑火。\n\n「圣光——堕——落——」它嘶嘶地说。",
      "choices": [
        {
          "text": "【净化】以圣光重新祝圣这座圣堂",
          "isCombat": true, "combatThreshold": 40,
          "bonusClasses": ["priest"],
          "successNodeId": "cc_priest_done", "failureNodeId": "cc_priest_hurt",
          "failHpDelta": -20, "failMoraleDelta": -15,
          "grantedFlags": ["lvl_11"]
        }
      ]
    },
    {
      "id": "cc_priest_done",
      "locationTitle": "魔王城 · 地下圣堂",
      "musicKey": "castle_theme",
      "type": "narrative",
      "text": "圣光在圣堂重新燃起——暗影恶魔在尖啸中被烧成了灰。\n\n圣坛恢复了往日的纯净。你在这里感受到了久违的安宁——虽然只有片刻。\n\n你起身——走向通往城堡上层的楼梯。",
      "nextNodeId": "cc_gate_converge",
      "hpDelta": 0, "moraleDelta": 15
    },
    {
      "id": "cc_priest_hurt",
      "locationTitle": "魔王城 · 地下圣堂",
      "musicKey": "castle_theme",
      "type": "narrative",
      "text": "暗影恶魔比你预想的更顽强——净化它耗费了大量的圣力。圣坛虽然恢复了，但你已经筋疲力尽。\n\n休息片刻后——你继续向上。",
      "nextNodeId": "cc_gate_converge",
      "hpDelta": 0, "moraleDelta": 0
    },

    {
      "id": "cc_gate_converge",
      "locationTitle": "魔王城 · 中央大厅",
      "musicKey": "castle_theme",
      "type": "choice",
      "text": "你进入了魔王城的中央大厅——四条通道通往四座塔楼。每座塔楼上都坐镇着一位魔王军的天王。\n\n必须击败他们——才能打开通往王座的大门。\n\n你先挑战哪一座？",
      "choices": [
        {
          "text": "【南塔·炎将】火之将军 — 烈焰与毁灭的化身 [勇者/射手擅长]",
          "nextNodeId": "cc_fire_general",
          "bonusClasses": ["hero", "archer"]
        },
        {
          "text": "【北塔·冰将】冰之将军 — 冻结一切的寒冰领主 [战士/法师擅长]",
          "nextNodeId": "cc_ice_general",
          "bonusClasses": ["warrior", "mage"]
        },
        {
          "text": "【东塔·岚将】风暴将军 — 掌控雷电的狂战士 [射手/法师擅长]",
          "nextNodeId": "cc_storm_general",
          "bonusClasses": ["archer", "mage"]
        },
        {
          "text": "【西塔·影将】暗影将军 — 无形暗杀者 [牧师/勇者擅长]",
          "nextNodeId": "cc_shadow_general",
          "bonusClasses": ["priest", "hero"]
        }
      ]
    },

    {
      "id": "cc_fire_general",
      "locationTitle": "南塔 · 炎将之间",
      "musicKey": "boss_theme",
      "type": "choice",
      "text": "火之将军——一个熔岩构成的巨人。整个房间被它身上的热量烤得扭曲。\n\n「来——让火焰净化你的一切——」\n\n它举起熔岩巨拳。",
      "choices": [
        {
          "text": "【精准打击】瞄准熔岩核心的裂缝",
          "isCombat": true, "combatThreshold": 60, "bonusClasses": ["hero", "archer"],
          "successNodeId": "cc_fire_win", "failureNodeId": "cc_fire_fail",
          "failHpDelta": -30, "failMoraleDelta": -20
        },
        {
          "text": "【水系法术】[需法师] 用冰水魔法克制火焰",
          "classRestricted": true, "allowedClasses": ["mage"],
          "isCombat": true, "combatThreshold": 50, "bonusClasses": ["mage"],
          "successNodeId": "cc_fire_win", "failureNodeId": "cc_fire_fail",
          "failHpDelta": -20, "failMoraleDelta": -15
        }
      ]
    },
    {
      "id": "cc_fire_win",
      "locationTitle": "南塔 · 炎将之间",
      "musicKey": "victory_theme",
      "type": "narrative",
      "text": "炎将在绝望的咆哮中冷却——变成了一座漆黑的石像，然后裂开崩塌。\n\n四天王——还剩三个。",
      "nextNodeId": "cc_after_generals",
      "grantedFlags": ["defeated_fire_general", "lvl_12"],
      "hpDelta": 0, "moraleDelta": 15
    },
    {
      "id": "cc_fire_fail",
      "locationTitle": "南塔 · 炎将之间",
      "musicKey": "boss_theme",
      "type": "narrative",
      "text": "炎将把你的武器打飞——但你在最后一刻捡起一块碎石，精准地刺入了它的核心裂缝。\n\n它倒了。你也被烧得不轻——但你赢了。",
      "nextNodeId": "cc_after_generals",
      "grantedFlags": ["defeated_fire_general"],
      "hpDelta": 0, "moraleDelta": 5
    },

    {
      "id": "cc_ice_general",
      "locationTitle": "北塔 · 冰将之间",
      "musicKey": "boss_theme",
      "type": "choice",
      "text": "冰之将军——一个永恒冰棺中的女武神。她的呼吸就是暴风雪。\n\n「你的热血——将会在这里冻结——」\n\n冰晶从她身边蔓延开来——地面在你脚下结冰。",
      "choices": [
        {
          "text": "【蛮力突破】无视冰霜正面冲锋",
          "isCombat": true, "combatThreshold": 60, "bonusClasses": ["warrior", "hero"],
          "successNodeId": "cc_ice_win", "failureNodeId": "cc_ice_fail",
          "failHpDelta": -30, "failMoraleDelta": -20
        },
        {
          "text": "【火焰法术】[需法师] 用火系魔法融化冰晶",
          "classRestricted": true, "allowedClasses": ["mage"],
          "isCombat": true, "combatThreshold": 50, "bonusClasses": ["mage"],
          "successNodeId": "cc_ice_win", "failureNodeId": "cc_ice_fail",
          "failHpDelta": -20, "failMoraleDelta": -15
        }
      ]
    },
    {
      "id": "cc_ice_win",
      "locationTitle": "北塔 · 冰将之间",
      "musicKey": "victory_theme",
      "type": "narrative",
      "text": "冰棺碎裂——冰将在暖风中化为一滩清水。她最后的叹息像风声一样消失在塔中。\n\n四天王——还剩两个。",
      "nextNodeId": "cc_after_generals",
      "grantedFlags": ["defeated_ice_general", "lvl_12"],
      "hpDelta": 0, "moraleDelta": 15
    },
    {
      "id": "cc_ice_fail",
      "locationTitle": "北塔 · 冰将之间",
      "musicKey": "boss_theme",
      "type": "narrative",
      "text": "你的武器差点被冻在手里——但你最终还是突破了她的冰墙。冰将的头盔被你劈裂——她败了。\n\n不过你的手指现在还是冻僵的状态。",
      "nextNodeId": "cc_after_generals",
      "grantedFlags": ["defeated_ice_general"],
      "hpDelta": 0, "moraleDelta": 5
    },

    {
      "id": "cc_storm_general",
      "locationTitle": "东塔 · 岚将之间",
      "musicKey": "boss_theme",
      "type": "choice",
      "text": "风暴将军——一个驾驭雷电的鹰身恶魔。它在空中盘旋，每一次振翅都是一道劈雷。\n\n「凡人——飞不起来吧？那就——等死！」",
      "choices": [
        {
          "text": "【远程压制】用远程攻击封住它的飞行路线",
          "isCombat": true, "combatThreshold": 60, "bonusClasses": ["archer", "mage"],
          "successNodeId": "cc_storm_win", "failureNodeId": "cc_storm_fail",
          "failHpDelta": -30, "failMoraleDelta": -20
